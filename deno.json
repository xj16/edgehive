{
  "name": "@xj16/edgehive",
  "version": "0.1.0",
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read entrypoints/deno.ts",
    "demo": "deno run --allow-net --allow-env --allow-read scripts/demo.ts",
    "smoke": "deno run --allow-net --allow-env --allow-read scripts/smoke.ts",
    "test": "deno test --allow-net --allow-env --allow-read --no-check test/"
  },
  "imports": {
    "hono": "npm:hono@^4.6.14",
    "hono/": "npm:/hono@^4.6.14/"
  },
  "nodeModulesDir": "auto",
  "fmt": {
    "lineWidth": 100,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
