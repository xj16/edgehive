# EdgeHive configuration (all optional — sensible defaults are baked in).
# Copy to .env for local overrides. Works the same on Bun, Deno and Node.

# HTTP port the server binds to.
PORT=8787

# Firebase project id (matches firebase.json / .firebaserc).
GCLOUD_PROJECT=edgehive-demo

# Firestore & Auth emulator hosts (host:port). These are the Firebase defaults.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Set to "false" to force the in-memory store even if the emulator is running.
EDGEHIVE_USE_EMULATOR=true

# Secret used to sign EdgeHive's dev bearer tokens. CHANGE THIS in production.
EDGEHIVE_AUTH_SECRET=dev-secret-change-me

# --- Security / limits ------------------------------------------------------
# Comma-separated CORS allowlist. "*" allows any origin (fine for a public read
# API); set explicit origins in production, e.g. https://your-portfolio.example
EDGEHIVE_CORS_ORIGINS=*

# Max JSON request body size in bytes (writes + login). Default 64 KiB.
EDGEHIVE_MAX_BODY_BYTES=65536

# Per-IP write rate limiting (token bucket): sustained rate + burst capacity.
EDGEHIVE_WRITE_RATE_PER_SEC=20
EDGEHIVE_WRITE_BURST=40

# Per-IP login attempts allowed per minute.
EDGEHIVE_LOGIN_RATE_PER_MIN=10

# Max concurrent SSE subscriptions from a single IP.
EDGEHIVE_MAX_SSE_PER_IP=20

# Set "true" to require a valid bearer token on ALL routes, including reads
# (turns the public read feed into a private API).
EDGEHIVE_REQUIRE_AUTH_FOR_READS=false

# --- Demo mode --------------------------------------------------------------
# Set "1" (or "true") to self-seed realistic demo data on boot, so a fresh
# instance comes up already populated.
EDGEHIVE_DEMO=0
